{
  "manifest_version": 3,
  "name": "Prism Pick",
  "description": "Pick any color from a webpage and copy its HEX or RGB value.",
  "version": "1.0.0",
  "action": {
    "default_title": "Prism Pick",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"]
}
